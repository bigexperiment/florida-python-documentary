		{
			"timestamps": {
				"from": "00:04:08,600",
				"to": "00:04:12,200"
			},
			"offsets": {
				"from": 248600,
				"to": 252200
			},
			"text": " relying on scent detection to locate snakes buried in dense brush,"
		},
		{
			"timestamps": {
				"from": "00:04:12,200",
				"to": "00:04:14,400"
			},
			"offsets": {
				"from": 252200,
				"to": 254400
			},
			"text": " where humans simply cannot see them."
