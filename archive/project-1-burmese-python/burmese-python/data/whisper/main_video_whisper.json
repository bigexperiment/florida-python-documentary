		{
			"timestamps": {
				"from": "00:04:14,400",
				"to": "00:04:19,800"
			},
			"offsets": {
				"from": 254400,
				"to": 259800
			},
			"text": " Engineering teams have mounted 850 nanometer near-infrared cameras to state vehicles."
		},
		{
			"timestamps": {
				"from": "00:04:19,800",
				"to": "00:04:23,400"
			},
			"offsets": {
				"from": 259800,
				"to": 263400
			},
			"text": " This allows detection teams to scan the environment for python signatures"
		},
		{
			"timestamps": {
				"from": "00:04:23,400",
				"to": "00:04:25,400"
			},
			"offsets": {
				"from": 263400,
				"to": 265400
			},
			"text": " that are invisible to the human eye."
