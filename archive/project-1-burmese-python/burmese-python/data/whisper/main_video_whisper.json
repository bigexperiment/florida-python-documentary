		{
			"timestamps": {
				"from": "00:04:25,400",
				"to": "00:04:28,200"
			},
			"offsets": {
				"from": 265400,
				"to": 268200
			},
			"text": " Biologists are even analyzing the water itself."
		},
		{
			"timestamps": {
				"from": "00:04:28,200",
				"to": "00:04:31,400"
			},
			"offsets": {
				"from": 268200,
				"to": 271400
			},
			"text": " By testing for environmental DNA, or EDNA,"
