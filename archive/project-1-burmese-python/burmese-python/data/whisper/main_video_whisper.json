		{
			"timestamps": {
				"from": "00:03:57,800",
				"to": "00:04:00,800"
			},
			"offsets": {
				"from": 237800,
				"to": 240800
			},
			"text": " implant them with radio transmitters, and release them."
		},
		{
			"timestamps": {
				"from": "00:04:00,800",
				"to": "00:04:05,400"
			},
			"offsets": {
				"from": 240800,
				"to": 245400
			},
			"text": " These males then lead biologists directly to hidden breeding aggregations."
		},
		{
			"timestamps": {
				"from": "00:04:05,400",
				"to": "00:04:08,600"
			},
			"offsets": {
				"from": 245400,
				"to": 248600
			},
			"text": " The state has also deployed specially-trained canine units,"
