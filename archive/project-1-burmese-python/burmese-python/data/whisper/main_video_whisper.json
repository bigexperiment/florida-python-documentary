			"timestamps": {
				"from": "00:04:39,800",
				"to": "00:04:42,400"
			},
			"offsets": {
				"from": 279800,
				"to": 282400
			},
			"text": " but they highlight a difficult reality."
		},
		{
			"timestamps": {
				"from": "00:04:42,400",
				"to": "00:04:47,000"
			},
			"offsets": {
				"from": 282400,
				"to": 287000
			},
			"text": " Florida is currently forced to deploy millions of dollars in advanced tech"
		},
		{
			"timestamps": {
				"from": "00:04:47,000",
				"to": "00:04:51,200"
			},
			"offsets": {
				"from": 287000,
				"to": 291200
			},
			"text": " just to locate an enemy it hasn't yet found a way to eradicate."
		},
		{
			"timestamps": {
				"from": "00:04:51,200",
				"to": "00:04:55,000"
			},
			"offsets": {
				"from": 291200,
				"to": 295000
			},
			"text": " Recent genetic testing has uncovered a new complication."
		},
		{
			"timestamps": {
				"from": "00:04:55,000",
				"to": "00:04:59,000"
			},
			"offsets": {
				"from": 295000,
				"to": 299000
			},
			"text": " DNA analysis shows that the Burmese pythons in the Everglades"
		},
		{
			"timestamps": {
				"from": "00:04:59,000",
				"to": "00:05:02,600"
			},
			"offsets": {
				"from": 299000,
				"to": 302600
			},
			"text": " are now actively hybridizing with the Indian rock python."
		},
		{
			"timestamps": {
				"from": "00:05:02,600",
				"to": "00:05:06,000"
			},
			"offsets": {
				"from": 302600,
				"to": 306000
			},
			"text": " The Indian rock python is a smaller, faster species."
		},
		{
			"timestamps": {
				"from": "00:05:06,000",
				"to": "00:05:09,400"
			},
			"offsets": {
				"from": 306000,
				"to": 309400
			},
			"text": " This hybridization introduces increased genetic vigor,"
		},
		{
			"timestamps": {
				"from": "00:05:09,400",
				"to": "00:05:13,600"
			},
			"offsets": {
				"from": 309400,
				"to": 313600
			},
			"text": " creating a predator that is potentially more adaptable than its ancestors."
		},
		{
			"timestamps": {
				"from": "00:05:13,600",
				"to": "00:05:16,200"
			},
			"offsets": {
				"from": 313600,
				"to": 316200
			},
			"text": " The containment lines are already shifting."
		},
		{
			"timestamps": {
				"from": "00:05:16,200",
				"to": "00:05:20,800"
			},
			"offsets": {
				"from": 316200,
				"to": 320800
			},
			"text": " 2025 range data shows the pythons moving beyond the borders of South Florida"
		},
		{
			"timestamps": {
				"from": "00:05:20,800",
				"to": "00:05:23,800"
			},
			"offsets": {
				"from": 320800,
				"to": 323800
			},
			"text": " and pushing steadily into new counties to the north."
		},
		{
			"timestamps": {
				"from": "00:05:23,800",
				"to": "00:05:26,800"
			},
			"offsets": {
				"from": 323800,
				"to": 326800
			},
			"text": " With continued genetic adaptation and a warming climate,"
		},
		{
			"timestamps": {
				"from": "00:05:26,800",
				"to": "00:05:29,800"
			},
			"offsets": {
				"from": 326800,
				"to": 329800
			},
			"text": " researchers expect these cold-blooded invaders to eventually"
		},
		{
			"timestamps": {
				"from": "00:05:29,800",
				"to": "00:05:33,400"
			},
			"offsets": {
				"from": 329800,
				"to": 333400
			},
			"text": " survive in more temperate regions across the American Southeast."
		},
		{
			"timestamps": {
				"from": "00:05:33,400",
				"to": "00:05:39,000"
			},
			"offsets": {
				"from": 333400,
				"to": 339000
			},
			"text": " Total eradication in Florida is no longer considered a realistic scientific goal."
		},
		{
			"timestamps": {
				"from": "00:05:39,000",
				"to": "00:05:42,600"
			},
			"offsets": {
				"from": 339000,
				"to": 342600
			},
			"text": " The state has shifted its focus to permanent damage control"
		},
		{
			"timestamps": {
				"from": "00:05:42,600",
				"to": "00:05:45,600"
			},
			"offsets": {
				"from": 342600,
				"to": 345600
			},
			"text": " and the protection of specific habitats."
		},
		{
			"timestamps": {
				"from": "00:05:45,600",
				"to": "00:05:50,000"
			},
			"offsets": {
				"from": 345600,
				"to": 350000
			},
			"text": " The Burmese python proves how a single, unchecked invasive species"
		},
		{
			"timestamps": {
				"from": "00:05:50,000",
				"to": "00:05:54,400"
			},
			"offsets": {
				"from": 350000,
				"to": 354400
			},
			"text": " can permanently and irreversibly alter a fragile ecosystem."
		},
		{
			"timestamps": {
				"from": "00:05:54,400",
				"to": "00:05:58,000"
			},
			"offsets": {
				"from": 354400,
				"to": 358000
			},
			"text": " Florida is attempting to hold the line for its native species,"
		},
		{
			"timestamps": {
				"from": "00:05:58,000",
				"to": "00:06:01,200"
			},
			"offsets": {
				"from": 358000,
				"to": 361200
			},
			"text": " but it remains to be seen if the Everglades can endure,"
		},
		{
			"timestamps": {
				"from": "00:06:01,200",
				"to": "00:06:05,000"
			},
			"offsets": {
				"from": 361200,
				"to": 365000
			},
			"text": " or if the landscape has already been surrendered to the python."
		}
	]
}
