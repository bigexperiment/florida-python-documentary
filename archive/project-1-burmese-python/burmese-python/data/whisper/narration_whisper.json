		{
			"timestamps": {
				"from": "00:00:49,200",
				"to": "00:00:54,920"
			},
			"offsets": {
				"from": 49200,
				"to": 54920
			},
			"text": " overwhelmed owners drove to the nearest swamp and dumped them illegally into the wild,"
		},
		{
			"timestamps": {
				"from": "00:00:54,920",
				"to": "00:00:58,840"
			},
			"offsets": {
				"from": 54920,
				"to": 58840
			},
			"text": " seeding the wetlands with an apex predator."
