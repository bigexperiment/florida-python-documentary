		{
			"timestamps": {
				"from": "00:01:17,640",
				"to": "00:01:25,080"
			},
			"offsets": {
				"from": 77640,
				"to": 85080
			},
			"text": " For years, researchers dismissed sightings as isolated incidents, but by the year 2000,"
