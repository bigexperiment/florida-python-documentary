		{
			"timestamps": {
				"from": "00:00:58,840",
				"to": "00:01:05,960"
			},
			"offsets": {
				"from": 58840,
				"to": 65960
			},
			"text": " Then, in August of 1992, Hurricane Andrew, a Category 5 storm,"
