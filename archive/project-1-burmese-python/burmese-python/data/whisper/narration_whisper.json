		{
			"timestamps": {
				"from": "00:01:37,700",
				"to": "00:01:41,840"
			},
			"offsets": {
				"from": 97700,
				"to": 101840
			},
			"text": " A single female can lay up to 100 eggs per clutch."
		},
		{
			"timestamps": {
				"from": "00:01:41,840",
				"to": "00:01:45,200"
			},
			"offsets": {
				"from": 101840,
				"to": 105200
			},
			"text": " Their camouflage makes them nearly invisible,"
