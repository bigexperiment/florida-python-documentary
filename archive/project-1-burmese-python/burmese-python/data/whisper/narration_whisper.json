			"timestamps": {
				"from": "00:01:11,460",
				"to": "00:01:17,640"
			},
			"offsets": {
				"from": 71460,
				"to": 77640
			},
			"text": " releasing hundreds of snakes into the Everglades in a single catastrophic night."
