		{
			"timestamps": {
				"from": "00:01:28,120",
				"to": "00:01:33,720"
			},
			"offsets": {
				"from": 88120,
				"to": 93720
			},
			"text": " The pythons had become a fully established, self-reproducing population in the wild."
		},
		{
			"timestamps": {
				"from": "00:01:33,720",
				"to": "00:01:37,700"
			},
			"offsets": {
				"from": 93720,
				"to": 97700
			},
			"text": " These snakes have no natural predators in Florida."
